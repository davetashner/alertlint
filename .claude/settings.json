{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime --hook-json",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git worktree *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git reset *)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(bd *)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(go vet *)",
      "Bash(go mod *)",
      "Bash(gofmt *)",
      "Bash(golangci-lint *)",
      "Bash(python3 scripts/check_traceability.py)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)"
    ]
  }
}
